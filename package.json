{
  "name": "@aumos/mcp-trust-gate",
  "version": "0.1.0",
  "description": "MCP middleware for trust-based governance of AI agent tool calls",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["mcp", "trust", "governance", "ai-agents", "aumos"],
  "author": "MuVeraAI Corporation",
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "@aumos/types": ">=0.1.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "eslint": "^9.0.0",
    "@aumos/types": "^0.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
